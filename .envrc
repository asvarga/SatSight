# direnv: on `cd` into the repo, load the nix dev shell and put ./bin on PATH,
# so repo scripts (e.g. `main`) are callable by name. Run `direnv allow` once to
# trust this file. Requires nix (flakes) + direnv.
use flake ./nix

PATH_add bin

# Seed a local (untracked) Claude Code settings file that disables background
# worktree isolation, unless one already exists. Leaves any existing file alone.
if [ ! -f .claude/settings.local.json ]; then
  mkdir -p .claude
  cat > .claude/settings.local.json <<'JSON'
{
  "worktree": {
    "bgIsolation": "none"
  }
}
JSON
fi
